<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate DOCX in Browser</title>
    <!-- docx library -->
    <script src="https://unpkg.com/docx@8.5.0/build/index.js"></script>
    <!-- FileSaver for saving files -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
</head>
<body>
    <h1>JavaScript to DOCX Demo</h1>
    <button id="generate">Buat Dokumen</button>

    <script>
        // Ambil class dari docx
        const { Paragraph, TextRun, AlignmentType, BorderStyle, Document, Packer } = docx;

        // Warna default
        const C = {
            darkB: "00008B",
            blue: "0000FF",
            navy: "000080"
        };

        // Fungsi spacing
        function sp(b, a) {
            return { spacing: { before: b, after: a } };
        }

        // Fungsi dari script_lengkap.js
        function bigTitle(text, color = C.darkB) {
            return new Paragraph({
                alignment: AlignmentType.CENTER,
                ...sp(0, 80),
                children: [new TextRun({ text, bold: true, size: 36, color, font: "Arial" })]
            });
        }

        function subTitle(text, color = C.blue) {
            return new Paragraph({
                alignment: AlignmentType.CENTER,
                ...sp(0, 60),
                children: [new TextRun({ text, bold: true, size: 24, color, font: "Arial" })]
            });
        }

        function sectionBanner(text, color = C.navy) {
            return new Paragraph({
                ...sp(500, 100),
                border: {
                    bottom: { style: BorderStyle.THICK, size: 8, color, space: 1 },
                    top: { style: BorderStyle.THICK, size: 8, color, space: 1 },
                },
                children: [new TextRun({
                    text: `  ${text}  `,
                    bold: true,
                    size: 28,
                    color: "FFFFFF",
                    font: "Arial",
                    shading: { fill: color, type: "clear" }
                })]
            });
        }

        function sectionHeader(icon, text, color = C.navy) {
            return new Paragraph({
                ...sp(440, 80),
                border: { bottom: { style: BorderStyle.SINGLE, size: 6, color, space: 1 } },
                children: [
                    new TextRun({ text: `${icon} `, size: 24, color, font: "Arial" }),
                    new TextRun({ text: text.toUpperCase(), bold: true, size: 24, color, font: "Arial" }),
                ]
            });
        }

        function slideTag(num, title) {
            return new Paragraph({
                ...sp(340, 60),
                children: [
                    new TextRun({ text: `Slide ${num}: `, bold: true, size: 20, color: C.darkB, font: "Arial" }),
                    new TextRun({ text: title, size: 20, font: "Arial" })
                ]
            });
        }

        // Event tombol
        document.getElementById("generate").addEventListener("click", () => {
            const doc = new Document({
                sections: [{
                    children: [
                        bigTitle("Judul Besar"),
                        subTitle("Sub Judul"),
                        sectionBanner("Banner Section"),
                        sectionHeader("📌", "Header Section"),
                        slideTag(1, "Pengantar")
                    ]
                }]
            });

            Packer.toBlob(doc).then(blob => {
                saveAs(blob, "dokumen_hasil.docx");
            });
        });
    </script>
</body>
</html>
