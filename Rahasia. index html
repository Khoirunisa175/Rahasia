// === HELPER FUNCTIONS ===
const sp = (b=0, a=0) => ({ spacing: { before: b, after: a }});

function bigTitle(text, color=C.darkB) {
  return new Paragraph({
    alignment: AlignmentType.CENTER,
    ...sp(0, 80),
    children: [new TextRun({ text, bold: true, size: 36, color, font: "Arial" })]
  });
}

function subTitle(text, color=C.blue) {
  return new Paragraph({
    alignment: AlignmentType.CENTER,
    ...sp(0, 60),
    children: [new TextRun({ text, bold: true, size: 24, color, font: "Arial" })]
  });
}

function sectionBanner(text, color=C.navy) {
  return new Paragraph({
    ...sp(500, 100),
    border: {
      bottom: { style: BorderStyle.THICK, size: 8, color, space: 1 },
      top: { style: BorderStyle.THICK, size: 8, color, space: 1 },
    },
    children: [new TextRun({ text: `  ${text}  `, bold: true, size: 28, color: "FFFFFF", font: "Arial",
      shading: { fill: color, type: "clear" } })]
  });
}

function sectionHeader(icon, text, color=C.navy) {
  return new Paragraph({
    ...sp(440, 80),
    border: { bottom: { style: BorderStyle.SINGLE, size: 6, color, space: 1 } },
    children: [
      new TextRun({ text: `${icon} `, size: 24, color, font: "Arial" }),
      new TextRun({ text: text.toUpperCase(), bold: true, size: 24, color, font: "Arial" }),
    ]
  });
}

function slideTag(num, title) {
  return new Paragraph({
    ...sp(340, 60),
    children: [
      new TextRun({ text: `🎞 SLIDE ${num}  `, bold: true, size: 20, color: C.blue, font: "Arial" }),
      new TextRun({ text: `— ${title.toUpperCase()}`, bold: true, size: 20, color: C.navy, font: "Arial" }),
    ]
  });
}

function timer(t) {
  return new Paragraph({
    ...sp(40, 40),
    children: [new TextRun({ text: `⏱  ${t}`, italics: true, size: 19, color: C.orange, font: "Arial" })]
  });
}

function scriptLine(text) {
  return new Paragraph({
    ...sp(80, 60),
    indent: { left: 400 },
    children: [new TextRun({ text, size: 22, color: C.black, font: "Arial" })]
  });
}

function stageNote(text) {
  return new Paragraph({
    ...sp(40, 60),
    indent: { left: 400 },
    children: [new TextRun({ text: `📌 ${text}`, italics: true, size: 19, color: C.light, font: "Arial" })]
  });
}

function bullet(text, indent=720) {
  return new Paragraph({
    ...sp(40, 40),
    indent: { left: indent },
    children: [
      new TextRun({ text: "▸  ", bold: true, color: C.blue, size: 22, font: "Arial" }),
      new TextRun({ text, size: 22, color: C.black, font: "Arial" })
    ]
  });
}

function divider(color="DDDDDD") {
  return new Paragraph({
    ...sp(20, 20),
    border: { bottom: { style: BorderStyle.SINGLE, size: 2, color, space: 1 } },
    children: []
  });
}

function qaBox(type, speaker, text) {
  // type: 'Q' (penguji) or 'A' (mahasiswa)
  const isQ = type === 'Q';
  const bgColor = isQ ? "FFF3F3" : "F0F5FF";
  const labelColor = isQ ? C.penguji : C.mahasis;
  const label = isQ ? `❓ ${speaker}` : `💬 ${speaker}`;
  return [
    new Paragraph({
      ...sp(120, 0),
      children: [new TextRun({ text: label, bold: true, size: 21, color: labelColor, font: "Arial" })]
    }),
    new Paragraph({
      ...sp(0, 80),
      indent: { left: 400 },
      border: { left: { style: BorderStyle.SINGLE, size: 12, color: labelColor, space: 8 } },
      children: [new TextRun({ text, size: 21, color: C.black, font: "Arial" })]
    }),
  ];
}

function tipBox(text) {
  return new Paragraph({
    ...sp(60, 60),
    indent: { left: 400 },
    children: [
      new TextRun({ text: "💡 Tips: ", bold: true, size: 20, color: C.tipsCol, font: "Arial" }),
      new TextRun({ text, italics: true, size: 20, color: C.tipsCol, font: "Arial" })
    ]
  });
}

function qNum(n, topic) {
  return new Paragraph({
    ...sp(300, 60),
    children: [
      new TextRun({ text: `PERTANYAAN ${n}`, bold: true, size: 22, color: C.penguji, font: "Arial" }),
      new TextRun({ text: `  ·  ${topic}`, size: 22, color: C.gray, font: "Arial" }),
    ]
  });
}

function empty(before=80) {
  return new Paragraph({ ...sp(before, 0), children: [] });
}

